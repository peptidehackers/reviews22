{
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "pre-execution-governance": {
          "enabled": true
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "REDACTED_SET_VIA_ENV_OR_LOCAL_OVERRIDE"
    }
  },
  "skills": {
    "entries": {
      "apple-reminders": {
        "enabled": false
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "{{HOME}}/.openclaw/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.4"
      },
      "models": {
        "openai-codex/gpt-5.4": {}
      }
    }
  },
  "plugins": {
    "allow": [
      "openai",
      "memory-core"
    ],
    "entries": {
      "openai": {
        "enabled": true
      }
    }
  }
}
