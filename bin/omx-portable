#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT/scripts/lib/runtime-env.sh"

# Self-heal unless skipped
if [[ "${OMX_PORTABLE_SKIP_GUARD:-0}" != "1" ]]; then
    "$ROOT/scripts/self-heal.sh" --quiet 2>/dev/null || true
fi

exec "$OMX_OH_MY_CODEX_ROOT/dist/cli/omx.js" "$@"
